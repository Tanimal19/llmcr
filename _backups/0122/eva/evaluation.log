Question: Give me an example of using document joiner.

Answer: ```java
import java.util.List;
import java.util.Map;
import java.util.ArrayList;
import java.util.stream.Collectors;
import java.util.Comparator;
import java.util.function.Function;

public class DocumentJoinerExample {

    public static void main(String[] args) {
        // Sample data:  Map of Queries to lists of lists of Documents
        Map<Query, List<List<Document>>> documentsForQuery = Map.of(
            new Query("query1"), List.of(List.of(new Document("Content 1", Map.of("score", 0.9))), List.of(new Document("Content 2", Map.of("score", 0.8)))),
            new Query("query2"), List.of(List.of(new Document("Content 3", Map.of("score", 0.7))))
        );

        // Create a ConcatenationDocumentJoiner
        DocumentJoiner documentJoiner = new ConcatenationDocumentJoiner();

        // Join the documents
        List<Document> joinedDocuments = documentJoiner.join(documentsForQuery);

        // Print the joined documents
        for (Document doc : joinedDocuments) {
            System.out.println("Document ID: " + doc.getId() + ", Content: " + doc.getContent() + ", Score: " + doc.getScore());
        }
    }
}

// Dummy classes to represent Document and Query for the example to compile
class Document {
    private String id;
    private String content;
    private Map<String, Object> metadata;
    private Double score;

    public Document(String content, Map<String, Object> metadata) {
        this.content = content;
        this.metadata = metadata;
        this.id = "doc-" + content.hashCode(); // Simple ID generation
        this.score = (Double) metadata.get("score");
    }

    public String getId() {
        return id;
    }

    public String getContent() {
        return content;
    }

    public Map<String, Object> getMetadata() {
        return metadata;
    }

    public Double getScore() {
        return score;
    }
}

class Query {
    private String text;

    public Query(String text) {
        this.text = text;
    }

    public String getText() {
        return text;
    }
}
```

This example demonstrates how to use the `ConcatenationDocumentJoiner`.  It creates a sample `documentsForQuery` map, instantiates the joiner, calls the `join` method, and then prints the content and score of each document in the resulting joined list.  The `ConcatenationDocumentJoiner` combines all the documents from the different queries into a single list, removing duplicates (keeping the first occurrence), and sorts the resulting list by score in descending order.


