entBuilder(mock(ChatClient.Builder.class))\n+\t\t\t.targetSearchSystem("search engine")\n+\t\t\t.validationMode(ValidationMode.NONE)\n+\t\t\t.promptTemplate(customPromptTemplate)\n+\t\t\t.build();\n+\t\tvar logsList = listAppender.list;\n+\n+\t\tassertThat(logsList).isEmpty();\n+\t}\n+\n }\n'}
